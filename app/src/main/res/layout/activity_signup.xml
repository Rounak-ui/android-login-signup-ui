<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_style"
    tools:context=".Signup">

    <TextView
        android:id="@+id/textView"
        android:layout_width="0dp"
        android:layout_marginHorizontal="34dp"
        android:layout_height="wrap_content"
        android:layout_marginVertical="34dp"
        android:gravity="center"
        android:text="Welcome"
        android:textColor="#EBEAEA"
        android:textSize="48sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/terms_text"
        android:layout_width="0dp"
        android:layout_marginHorizontal="24dp"
        android:layout_height="89dp"
        android:gravity="center"
        android:padding="20dp"
        android:text="By continuing, you agree to our Terms of Service and Privacy Policy."
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Please signup to continue"
        android:textColor="#BAB8B8"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_gravity="center"
        android:background="@drawable/rounded_bg"
        android:elevation="10dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.591">

        <EditText
            android:id="@+id/edittxt_Email"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:elevation="2dp"
            android:ems="10"
            android:drawablePadding="7dp"
            android:gravity="center_vertical"
            android:fadingEdgeLength="2dp"
            android:drawableStart="@drawable/email_logo"
            android:hint=" Email"
            android:inputType="textEmailAddress"
            android:padding="15dp"
            android:singleLine="true"
            android:textColor="#050505"
            android:textColorHint="#2A2929"
            android:textSize="16sp"/>

        <EditText
            android:id="@+id/edittxt_Password"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:elevation="2dp"
            android:ems="10"
            android:gravity="center_vertical"
            android:fadingEdgeLength="2dp"
            android:hint="Password"
            android:drawablePadding="7dp"
            android:drawableStart="@drawable/lock_logo"
            android:inputType="textPassword"
            android:padding="15dp"
            android:singleLine="true"
            android:textColor="#050505"
            android:textColorHint="#2A2929"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/edittxt_rePassword"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:elevation="2dp"
            android:ems="10"
            android:gravity="center_vertical"
            android:fadingEdgeLength="2dp"
            android:hint="Re-Enter Password"
            android:inputType="textPassword"
            android:padding="15dp"
            android:singleLine="true"
            android:textColor="#050505"
            android:textColorHint="#2A2929"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="horizontal"
            android:paddingLeft="10dp"
            android:paddingRight="10dp">

            <TextView
                android:id="@+id/textView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:text="Already have an account?"
                android:textColor="#BAB8B8"
                android:textSize="16dp"
                android:paddingTop="3dp"/>

            <TextView
                android:id="@+id/login_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Login"
                android:paddingLeft="3dp"
                android:textSize="16dp"
                android:paddingTop="3dp"
                android:textColor="#2A2929"
                android:textStyle="bold" />

        </LinearLayout>

        <Button
            android:id="@+id/signup_btn"
            android:layout_width="match_parent"
            android:layout_marginHorizontal="24dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:alpha="0.7"
            android:backgroundTint="#2A2929"
            android:elevation="5dp"
            android:text="Sign-Up"
            android:textStyle="bold"
            android:textColor="#E7E4E4"
            android:textSize="20sp"
            app:rippleColor="#BFE0DCDC" />
        <TextView
            android:id="@+id/textView5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="12dp"
            android:text="contiue with"
            android:textColor="#BAB8B8"
            android:textSize="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/google_login"
                android:layout_width="0dp"
                android:layout_marginHorizontal="8dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                app:srcCompat="@drawable/google_symbol_1" />

            <ImageView
                android:id="@+id/apple_login"
                android:layout_width="0dp"
                android:layout_marginHorizontal="8dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                app:srcCompat="@drawable/apple_logo_1" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>